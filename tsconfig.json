{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "script.js",
    "script-helpers.mjs",
    "log-common.mjs",
    "logger.mjs",
    "frontend-logger.mjs",
    "error-messages.mjs",
    "server.mjs",
    "logs-tail.mjs",
    "build.mjs",
    "tests/**/*.mjs"
  ]
}
